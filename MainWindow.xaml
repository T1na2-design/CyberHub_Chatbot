<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CybersecurityChatbot"
        Title="CyberHub Chatbot - Part 3" Height="700" Width="1000"
        Background="#1E1E2E" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header / ASCII Art -->
        <TextBlock Grid.Row="0" x:Name="HeaderAscii" FontFamily="Consolas" Foreground="#00FF00" 
                   TextAlignment="Center" FontSize="10" Margin="0,0,0,10"/>
        
        <!-- User Info Bar -->
        <Border Grid.Row="1" Background="#282A36" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="White" FontWeight="Bold" Text="User: "/>
                <TextBlock x:Name="UserNameTxt" Foreground="#8BE9FD" Text="Guest"/>
                <TextBlock Foreground="White" FontWeight="Bold" Text=" | Interests: " Margin="20,0,0,0"/>
                <TextBlock x:Name="UserInterestsTxt" Foreground="#FF79C6" Text="None"/>
            </StackPanel>
        </Border>

        <!-- TabControl for different features -->
        <TabControl Grid.Row="2" Background="#282A36" Foreground="White">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#282A36"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding" Value="15,8"/>
                </Style>
            </TabControl.Resources>

            <!-- Chat Tab -->
            <TabItem Header="💬 Chat" Foreground="White">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <ScrollViewer Grid.Row="0" x:Name="ChatScrollViewer" Background="#282A36" Margin="0,0,0,10">
                        <StackPanel x:Name="ChatPanel" Margin="10"/>
                    </ScrollViewer>

                    <!-- Input Area -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox Grid.Column="0" x:Name="InputBox" Background="#44475A" Foreground="White" 
                                 FontSize="16" Padding="5" KeyDown="InputBox_KeyDown" />
                        <Button Grid.Column="1" Content="Send" Width="80" Margin="10,0,0,0" 
                                Background="#50FA7B" Foreground="Black" FontWeight="Bold" Click="SendBtn_Click"/>
                        <Button Grid.Column="2" Content="Clear" Width="80" Margin="10,0,0,0" 
                                Background="#FF5555" Foreground="White" FontWeight="Bold" Click="ClearChatBtn_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Task Manager Tab -->
            <TabItem Header="📋 Tasks" Foreground="White">
                <local:TaskManagerControl x:Name="TaskManagerTab" Margin="10"/>
            </TabItem>

            <!-- Quiz Tab -->
            <TabItem Header="🎯 Quiz" Foreground="White">
                <local:QuizControl x:Name="QuizTab" Margin="10"/>
            </TabItem>

            <!-- Activity Log Tab -->
            <TabItem Header="📊 Activity Log" Foreground="White">
                <local:ActivityLogControl x:Name="ActivityLogTab" Margin="10"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
