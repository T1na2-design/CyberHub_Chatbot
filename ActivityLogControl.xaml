<UserControl x:Class="CybersecurityChatbot.ActivityLogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E2E" Foreground="#F8F8F2">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📊 Activity Log" FontSize="20" FontWeight="Bold" 
               Foreground="#8BE9FD" Margin="0,0,0,10"/>

        <!-- Stats Bar -->
        <Border Grid.Row="1" Background="#232536" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="#C4C8D4" Text="Total Entries: "/>
                <TextBlock x:Name="TotalEntriesTxt" Foreground="#F8F8F2" Text="0"/>
            </StackPanel>
        </Border>

        <!-- Activity ListView -->
        <ListBox Grid.Row="2" x:Name="ActivityListBox" Background="#232536" Foreground="#F8F8F2"
                 Margin="0,0,0,10" ItemsSource="{Binding}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="#2E3145" CornerRadius="4" Padding="10" Margin="0,3">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <TextBlock Foreground="#AAB2C8" Text="[" FontWeight="Bold"/>
                                <TextBlock Foreground="#D7DCF0" Text="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}" FontWeight="Bold"/>
                                <TextBlock Foreground="#AAB2C8" Text="]" FontWeight="Bold"/>
                                <Border Background="#3A3E57" CornerRadius="3" Padding="6,2" Margin="10,0,0,0">
                                    <TextBlock Foreground="#8BE9FD" Text="{Binding Category}" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Foreground="#F8F8F2" Text="{Binding Action}" TextWrapping="Wrap" Margin="0,2,0,0" FontWeight="SemiBold"/>
                            <TextBlock Foreground="#C4C8D4" Text="{Binding Details}" TextWrapping="Wrap" Margin="0,3,0,0" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Button Panel -->
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Button Content="Refresh" Width="100" Background="#50FA7B" Foreground="Black" 
                    FontWeight="Bold" Click="RefreshBtn_Click" Margin="0,0,10,0"/>
            <Button Content="Clear All" Width="100" Background="#FF5555" Foreground="White" 
                    FontWeight="Bold" Click="ClearBtn_Click" Margin="0,0,10,0"/>
            <Button Content="Export" Width="100" Background="#BD93F9" Foreground="White" 
                    FontWeight="Bold" Click="ExportBtn_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
